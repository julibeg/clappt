#!/usr/bin/env python3
import json
import pathlib
import subprocess
import shutil
import sys

input_data = json.load(sys.stdin)

if input_data.get("tool_name") != "Bash":
    sys.exit(0)

# make sure `scrub` is on the path and executable
if not shutil.which("scrub"):
    sys.stderr.write("scrub not available\n")
    sys.exit(2)

# make sure `rtk` is on the path and executable
if not shutil.which("rtk"):
    sys.stderr.write("rtk not available\n")
    sys.exit(2)

original_command = input_data.get("tool_input", {}).get("command", "")
updated_input = input_data.get("tool_input", {}).copy()
rtk_output = {}

rtk_rewrite_path = pathlib.Path(__file__).resolve().parent / "rtk-rewrite.sh"
if not rtk_rewrite_path.exists():
    sys.stderr.write("rtk-rewrite.sh not available\n")
    sys.exit(2)

try:
    result = subprocess.run(
        [str(rtk_rewrite_path)],
        input=json.dumps(input_data),
        capture_output=True,
        text=True,
        check=False,
    )
    if result.returncode == 0 and result.stdout.strip():
        parsed = json.loads(result.stdout)
        hook_output = parsed.get("hookSpecificOutput", {})
        candidate_updated = hook_output.get("updatedInput")
        if isinstance(candidate_updated, dict):
            updated_input = candidate_updated.copy()
        rtk_output = hook_output
except (OSError, json.JSONDecodeError):
    pass

# wrap the command
wrapped = updated_input.get("command", original_command).strip()
if not wrapped.endswith("2>&1"):
    wrapped += " 2>&1"
wrapped += " | scrub"

# there are other options to wrap the command, but hey have issues:
# - wrapped = f"bash-san -c {shlex.quote(original_command)}"
#   - This is is nice because it gives us full control over how to handle both stdout
#     and stderr in the bash-san script, but, if `bash-san` is added to the allow-list,
#     it allows all commands to be run and we'd lose granular control
# - wrapped = f"{original_command} 2> >(scrub >&2) > >(scrub)"
#   - This is too much bash magic which claude apparently doesn't like and so it doesn't
#     ask us if we want to allow it anymore (i.e. we have to rely on the hard-coded
#     "allow" or "ask" in the JSON input and then we're asked every time or never)

output = {
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "updatedInput": {**updated_input, "command": wrapped},
    }
}

permission_decision = rtk_output.get("permissionDecision")
if permission_decision is not None:
    valid_permission_decisions = {"allow", "ask", "deny", "defer"}
    if permission_decision not in valid_permission_decisions:
        sys.stderr.write(
            f"invalid permissionDecision from rtk-rewrite.sh: {permission_decision}\n"
        )
        sys.exit(2)
    output["hookSpecificOutput"]["permissionDecision"] = permission_decision

permission_reason = rtk_output.get("permissionDecisionReason")
if isinstance(permission_reason, str) and permission_reason:
    output["hookSpecificOutput"]["permissionDecisionReason"] = permission_reason

print(json.dumps(output))
